rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    function isPublic(uid) {
      return exists(/databases/$(database)/documents/publicProfiles/$(uid))
        && get(/databases/$(database)/documents/publicProfiles/$(uid)).data.enabled == true;
    }

    match /publicProfiles/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /transactions/{txId} {
        allow read: if isOwner(uid) || isPublic(uid);
        allow write: if isOwner(uid);
      }

      match /budgets/{monthId} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
